# QQ 邮箱配置
QQ_EMAIL=your_qq_email@qq.com
QQ_AUTH_CODE=your_qq_auth_code

# 收件人邮箱（支持多个，用逗号或分号分隔）
# 单个邮箱: TO_EMAIL=recipient@example.com
# 多个邮箱: TO_EMAIL=user1@example.com,user2@example.com,user3@example.com
TO_EMAIL=recipient@example.com

# SMTP 配置（可选，默认使用 QQ 邮箱）
SMTP_SERVER=smtp.qq.com
SMTP_PORT=587

# HLTV 配置（可选）
HLTV_BASE_URL=https://hltv.org

# Steam 配置（可选）
STEAM_APP_ID=730
